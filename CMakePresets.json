{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Tesla T4 / SM70)",
      "description": "Build for Tesla T4 GPU (Compute Capability 7.0)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "70",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "native",
      "displayName": "Native (auto-detect GPU)",
      "description": "Auto-detect the local GPU architecture (requires CMake 3.23+)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/native",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "native",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ampere",
      "displayName": "Ampere (RTX 3080 / SM86)",
      "description": "Build for Ampere architecture (Compute Capability 8.6)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ampere",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (native, optimized)",
      "description": "Optimized release build targeting the local GPU",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "native",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "native",
      "configurePreset": "native"
    },
    {
      "name": "ampere",
      "configurePreset": "ampere"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
